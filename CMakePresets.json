{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x86-windows",
      "displayName": "Windows 32-bit (clang-cl, vcpkg)",
      "inherits": "base",
      "generator": "Visual Studio 18 2026",
      "architecture": { "value": "Win32", "strategy": "set" },
      "toolset": { "value": "ClangCL", "strategy": "set" },
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x86-windows-static" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "x86-linux",
      "displayName": "Linux 32-bit (clang, vcpkg)",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-linux",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS": "-m32",
        "CMAKE_C_FLAGS": "-m32"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    }
  ],
  "buildPresets": [
    { "name": "x86-windows", "configurePreset": "x86-windows" },
    { "name": "x86-linux",   "configurePreset": "x86-linux" }
  ]
}
